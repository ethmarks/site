---
import sharp from "sharp";
import { Image } from "astro:assets";

const { image, url, alt, title, desc, transparent } = Astro.props;

let dominantColor = "rgba(0,0,0,0)";

if (image.fsPath && !transparent) {
    const stats = await sharp(image.fsPath).stats();
    const [r, g, b] = stats.channels.map((c) => Math.round(c.mean));
    dominantColor = `rgb(${r}, ${g}, ${b})`;
}
---

<a href={url} class="card">
    <div class="card-img-wrapper">
        <Image
            src={image}
            alt={alt}
            style={`background: ${dominantColor}`}
            class="card-image"
        />
    </div>
    <div class="card-text">
        <h4>{title}</h4>
        <p>{desc}</p>
    </div>
</a>

<style lang="scss">
    :root {
        --card-gap: var(--spacing-lg);
        --card-img-radius: var(--radius-lg) var(--radius-lg) var(--radius-sm)
            var(--radius-sm);
    }

    .card {
        background: var(--color-card);
        border-radius: var(--radius-lg);
        border: var(--border-light);
        transition:
            transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            border 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        box-shadow: var(--shadow-standard);
        color: var(--color-text);
        text-decoration: none;

        .card-img-wrapper {
            width: 100%;
            height: 160px;
            border-radius: var(--card-img-radius);
            clip-path: inset(-1px round var(--card-img-radius));
            transition: clip-path 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;

            @media (max-width: 768px) {
                &::after {
                    content: "";
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    height: 5px;
                    background: linear-gradient(
                        to bottom,
                        transparent,
                        var(--color-card)
                    );
                    z-index: 2;
                    pointer-events: none;
                }
            }
        }

        .card-image {
            width: 100%;
            height: 160px;
            object-fit: cover;
            border-radius: var(--card-img-radius);
            transition:
                transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-radius 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            display: block;
            position: relative;
            z-index: 1;
        }

        .card-text {
            padding: var(--spacing-xs) var(--spacing-lg) var(--spacing-lg);
        }

        h4 {
            margin: var(--spacing-xs) 0;
            font-size: var(--font-size-h4);
            font-family: var(--font-secondary);
            color: var(--color-link);
            line-height: 1.3;
            transition: text-shadow 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        p {
            margin: 0;
            padding: 0;
            font-size: var(--font-size-sm);
            color: var(--color-text-secondary);
            line-height: 1.5;
            transition: color 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        &:hover,
        &.centeredInView {
            box-shadow: var(--shadow-standard-hover);
            border-color: var(--color-accent-transparent-30);
            text-decoration: none;

            @media (pointer: fine) {
                transform: translateY(-3px) scale(0.99);
                .card-img-wrapper {
                    clip-path: inset(-16px round var(--radius-lg));
                }

                .card-image {
                    transform: scale(1.12) translateY(-8px);
                    border-radius: var(--radius-lg);
                    box-shadow: 0 10px 10px rgba(0, 0, 0, 0.15);
                }
            }

            @media (pointer: coarse) {
                transform: translateY(-3px) scale(1.03);
            }

            h4 {
                text-shadow: var(--shadow-accent);
            }

            p {
                color: var(--color-text);
            }
        }
    }
</style>

<script>
    function isMobile() {
        return (
            window.innerWidth <= 768 &&
            window.matchMedia("(pointer: coarse)").matches
        );
    }

    function updateActiveCard() {
        if (!isMobile()) return;

        const cards = document.querySelectorAll(".card");
        if (!cards.length) return;

        const viewportCenter = window.innerHeight / 2;

        cards.forEach((card) => {
            // checks if viewport's exact center is inside the card
            const cardBounds = card.getBoundingClientRect();
            const intersects =
                cardBounds.top <= viewportCenter &&
                cardBounds.bottom >= viewportCenter;
            card.classList.toggle("centeredInView", intersects);
        });
    }

    function initCardScroll() {
        if (!isMobile()) return;

        updateActiveCard();
        window.addEventListener("scroll", updateActiveCard);
        window.addEventListener("resize", updateActiveCard);

        document.querySelectorAll(".card").forEach((card) => {
            card.addEventListener("click", () => {
                document.querySelectorAll(".card").forEach((c) => {
                    c.classList.remove("centeredInView");
                });
            });
        });
    }

    initCardScroll();
    document.addEventListener("astro:after-swap", initCardScroll);
</script>
